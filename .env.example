# Penned Configuration

# Server
PORT=3000
BASE_URL=https://penned.ca

# JWT — set a STABLE random value; if unset, sessions break on every restart.
JWT_SECRET=your-random-secret-here

# Database — MUST live on a persistent disk in production (e.g. a Render disk),
# otherwise all user accounts are wiped on every deploy. Defaults to ./esign.db.
DB_PATH=/var/data/esign.db

# Email (Resend — preferred, works over HTTPS)
RESEND_API_KEY=re_xxxxxxxx

# Email (SMTP — fallback)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
# Must be verified with your email provider (Resend, SMTP, etc.)
FROM_EMAIL=penned@digitalbuilders.ca
FROM_NAME=Penned
# Public support/reply-to address shown to users
CONTACT_EMAIL=hello@penned.ca

# Stripe Billing
STRIPE_SECRET_KEY=sk_live_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
STRIPE_PRICE_ID_UNLIMITED=price_xxxxxxxx
